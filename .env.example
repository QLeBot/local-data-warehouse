# Copy to .env and fill in. Used by ingest scripts (snowflake_extract, snowflake_dbt_pull) and
# optionally by Snowflake CLI or MCP client config. Do not commit .env.

# --- Snowflake (required for Snowflake extract / dbt pull) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
# SNOWFLAKE_ROLE=

# --- Optional overrides (defaults used by scripts if unset) ---
# Path to DuckDB warehouse (default: warehouse/local.duckdb)
# WAREHOUSE_PATH=warehouse/local.duckdb
# dbt project dir for Snowflake-pulled project (e.g. dbt/my_snowflake_project)
# DBT_SNOWFLAKE_PROJECT=dbt/my_snowflake_project
# Stage for dbt pull (e.g. @MY_DB.MY_SCHEMA.DBT_STAGE)
# SNOWFLAKE_DBT_STAGE=
